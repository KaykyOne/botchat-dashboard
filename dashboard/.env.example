# URL da API/backend que responde por /start e /disconnect.
# Pegue a partir do endereço do serviço que expõe essas rotas.
NEXT_PUBLIC_URL=

# URL do projeto Supabase. No painel do Supabase: Project Settings > API > Project URL.
NEXT_PUBLIC_APIURL=

# Chave pública anon do Supabase. No painel do Supabase: Project Settings > API > Project API keys > anon public.
NEXT_PUBLIC_SUPABASE=
